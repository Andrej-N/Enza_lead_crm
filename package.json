{
  "name": "enza-lead-database",
  "version": "1.0.0",
  "description": "Lead tracking app for Enza Home partnership",
  "scripts": {
    "server": "node server/index.js",
    "client": "cd client && npm run dev",
    "import": "node server/import.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "start": "node server/index.js",
    "setup": "npm install && cd client && npm install && cd .. && npm run import"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.4.1",
    "express": "^4.18.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.1",
    "sql.js": "^1.10.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
